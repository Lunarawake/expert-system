# 大模型接口配置 —— 填入对应平台 API Key 后启动即可使用
LLM_API_KEY=sk-9640480d8b534500855a9890fa88942c
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_NAME=deepseek-v4-flash

# 中文 Embedding 模型（默认已支持中文，无需修改）
EMBEDDING_MODEL_NAME=shibing624/text2vec-base-chinese

# ChromaDB 存储路径：不再在此配置相对路径，config.py 会自动定位到 backend/ 目录下的 chroma_db
